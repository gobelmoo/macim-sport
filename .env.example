# ── Database (Neon) ──────────────────────────────────────────
# จาก Vercel Marketplace → Neon → ติดตั้งใน Vercel project แล้ว `vercel env pull`
DATABASE_URL=
# แยก Neon branch สำหรับเทส (vitest บังคับต้องมีและต้องต่างจาก DATABASE_URL)
TEST_DATABASE_URL=

# ── Auth.js (NextAuth v5) ────────────────────────────────────
# สร้างด้วย: openssl rand -base64 32  (หรือ `npx auth secret`)
AUTH_SECRET=
# Production URL ตั้งโดย Vercel อัตโนมัติ; dev ใช้ http://localhost:3000
AUTH_URL=http://localhost:3000

# ── Seed: Owner Account ──────────────────────────────────────
# ใช้แค่ตอน pnpm db:seed เพื่อสร้าง owner account แรก
SEED_OWNER_EMAIL=
SEED_OWNER_PASSWORD=
